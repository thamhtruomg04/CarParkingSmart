<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#4CAF50"
        android:elevation="4dp"
        app:title="Trạm Sạc Thông Minh"
        app:titleTextColor="#FFFFFF" />



    <!-- Bản đồ -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Thanh tìm kiếm phía trên với gradient xanh lá -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:backgroundTint="#FFFFFF">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="2dp"
            android:gravity="center_vertical|center_horizontal"

            android:background="@drawable/gradient_green_bg">
            <!-- Logo Trạm Sạc Xe Điện -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="8dp"
                android:src="@drawable/ic_ev_charging"
                android:contentDescription="EV Charging Logo" />
            <AutoCompleteTextView
                android:id="@+id/search_box"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Tìm trạm sạc gần bạn..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:importantForAutofill="no"
                android:background="@null"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#E0F2F1"
                android:singleLine="true"
                android:paddingStart="4dp"
                android:paddingEnd="8dp"
                android:dropDownHeight="300dp"
                android:completionThreshold="2" />
            <!-- Icon microphone -->
            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voice search"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="#FFFFFF" />
            <!-- Avatar -->
            <ImageView
                android:id="@+id/user_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_electric_car"
                android:contentDescription="User Avatar"
                android:background="@drawable/circle_button" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:scrollbars="none">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_wards"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true"
            app:singleSelection="true"
            android:paddingEnd="12dp" />
    </HorizontalScrollView>

    <!-- Các nút chức năng bên phải (góc dưới phải) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="160dp"
        android:orientation="vertical">
        <!-- Nút Layers -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">
            <ImageButton
                android:id="@+id/btn_layers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Layers"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="#4CAF50" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút danh sách trạm sạc -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#4CAF50">
            <Button
                android:id="@+id/btn_show_parking_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="⚡"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút My Location -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">
            <ImageButton
                android:id="@+id/btn_my_location"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Vị trí của tôi"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="#4CAF50" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">
            <ImageButton
                android:id="@+id/btn_theme_toggle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_recent_history"
                android:contentDescription="Đổi giao diện"
                app:tint="#4CAF50" />
        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FF5252"> <ImageButton
            android:id="@+id/btn_logout_map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Đăng xuất"
            android:src="@android:drawable/ic_lock_power_off"
            app:tint="#FFFFFF" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Nút Directions (FAB ở dưới trái)
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_directions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:contentDescription="Chỉ đường"
        android:src="@android:drawable/ic_menu_directions"
        app:tint="#FFFFFF"
        app:backgroundTint="#4CAF50"
        app:elevation="8dp"
        app:borderWidth="0dp" />
    -->
    <!-- Bottom Sheet - Thông tin trạm sạc -->

    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Handle Bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#81C784"
            android:radius="2dp" />

        <!-- Header: Thông tin trạm sạc + Nút đóng (X) cách xa nhau -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Thông tin trạm sạc"
                android:textSize="16sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <ImageButton
                android:id="@+id/btn_close_sheet"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Đóng"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#4CAF50" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:padding="4dp"
            android:background="@drawable/chip_charging_bg"> <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_battery_charging"
            app:tint="#FF5722" />

            <TextView
                android:id="@+id/tv_live_occupancy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Đang có 5 người sạc tại đây"
                android:textColor="#E64A19"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tên trạm sạc -->
        <TextView
            android:id="@+id/tv_place_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên trạm sạc"
            android:textSize="22sp"
            android:textColor="#1B5E20"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Rating và category -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tv_place_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang tải..."
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textSize="14sp"
                android:textColor="#4CAF50" />
            <TextView
                android:id="@+id/tv_place_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạm sạc nhanh"
                android:textSize="14sp"
                android:textColor="#4CAF50" />
        </LinearLayout>

        <!-- Địa chỉ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="#4CAF50" />
            <TextView
                android:id="@+id/tv_place_address"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Địa chỉ"
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Khoảng cách -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="#4CAF50" />
            <TextView
                android:id="@+id/tv_place_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.5 km từ vị trí của bạn"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Các nút hành động (Nút chọn map, trở về vị trí, đăng xuất) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:id="@+id/btn_save_place"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="#4CAF50" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lưu"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_share_place"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="#4CAF50" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chia sẻ"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_nearby"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#4CAF50" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gần đây"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hai nút đặt chỗ sạc ngang nhau -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:weightSum="2">

            <!-- Nút Đặt chỗ sạc trước -->
            <Button
                android:id="@+id/btn_book_parking_later"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="ĐẶT CHỖ SẠC TRƯỚC"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/gradient_green_bg"
                android:layout_marginEnd="8dp"
                android:elevation="4dp" />

            <!-- Nút Đặt chỗ sạc ngay -->
            <Button
                android:id="@+id/btn_book_parking"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="ĐẶT CHỖ SẠC NGAY"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/gradient_green_bg"
                android:layout_marginStart="8dp"
                android:elevation="4dp" />

        </LinearLayout>

        <!-- Nút chỉ đường lớn -->
        <Button
            android:id="@+id/btn_directions_bottom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Chỉ đường đến trạm sạc"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/gradient_green_bg"
            android:textAllCaps="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:gravity="center"
            android:elevation="4dp"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>