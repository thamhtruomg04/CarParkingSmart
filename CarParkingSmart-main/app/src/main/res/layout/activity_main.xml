<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9">

    <!-- Bản đồ -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Thanh tìm kiếm phía trên với gradient xanh lá -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:backgroundTint="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_green_bg">

            <!-- Logo Trạm Sạc Xe Điện -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="8dp"
                android:src="@drawable/ic_ev_charging"
                android:contentDescription="EV Charging Logo" />

            <AutoCompleteTextView
                android:id="@+id/search_box"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Tìm trạm sạc gần bạn..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:importantForAutofill="no"
                android:background="@null"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#E0F2F1"
                android:singleLine="true"
                android:paddingStart="4dp"
                android:paddingEnd="8dp"
                android:dropDownHeight="300dp"
                android:completionThreshold="2" />

            <!-- Icon microphone -->
            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voice search"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="#FFFFFF" />

            <!-- Avatar -->
            <ImageView
                android:id="@+id/user_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_electric_car"
                android:contentDescription="User Avatar"
                android:background="@drawable/circle_button" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Các chip category ngang - Chủ đề trạm sạc xe điện -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="12dp">

            <!-- Trạm sạc nhanh -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chip_restaurant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:backgroundTint="#4CAF50">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_fast_charging"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Sạc Nhanh"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trạm sạc thường -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chip_cafe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:backgroundTint="#66BB6A">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_battery_charging"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔋 Sạc Thường"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bãi đỗ xe điện -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chip_hotel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:backgroundTint="#81C784">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_electric_car"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚗 Bãi Đỗ EV"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trạm xanh - Eco -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chip_hospital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                android:backgroundTint="#A5D6A7">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_eco_leaf"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿 Eco Station"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Các nút chức năng bên phải (góc dưới phải) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="160dp"
        android:orientation="vertical">

        <!-- Nút Layers -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">

            <ImageButton
                android:id="@+id/btn_layers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Layers"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="#4CAF50" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút mở danh sách trạm sạc gần nhất -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#4CAF50">

            <Button
                android:id="@+id/btn_show_parking_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="⚡"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút My Location -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">

            <ImageButton
                android:id="@+id/btn_my_location"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Vị trí của tôi"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="#4CAF50" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút mới: Lưu vị trí xe -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#66BB6A">

            <Button
                android:id="@+id/btn_save_my_spot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="💾"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút mới: Tìm xe của tôi (ban đầu ẩn) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:backgroundTint="#81C784">

            <Button
                android:id="@+id/btn_find_my_spot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🔍"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:visibility="gone" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Nút Directions (FAB ở dưới trái) với gradient xanh -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_directions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:contentDescription="Chỉ đường"
        android:src="@android:drawable/ic_menu_directions"
        app:tint="#FFFFFF"
        app:backgroundTint="#4CAF50"
        app:elevation="8dp"
        app:borderWidth="0dp" />

    <!-- Bottom Sheet - Thông tin trạm sạc -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Nút đặt chỗ sạc -->
        <Button
            android:id="@+id/btn_book_parking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⚡ ĐẶT CHỖ SẠC NGAY"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/gradient_green_bg"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:elevation="4dp"
            android:visibility="gone" />

        <!-- Handle Bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#81C784"
            android:radius="2dp" />

        <!-- Header với nút đóng -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Thông tin trạm sạc"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_centerVertical="true" />

            <ImageButton
                android:id="@+id/btn_close_sheet"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Đóng"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#4CAF50" />

        </RelativeLayout>

        <!-- Tên trạm sạc -->
        <TextView
            android:id="@+id/tv_place_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên trạm sạc"
            android:textSize="22sp"
            android:textColor="#1B5E20"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Rating và category -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_place_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Còn 5 chỗ sạc"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textSize="14sp"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tv_place_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạm sạc nhanh"
                android:textSize="14sp"
                android:textColor="#4CAF50" />

        </LinearLayout>

        <!-- Địa chỉ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="#4CAF50" />

            <TextView
                android:id="@+id/tv_place_address"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Địa chỉ"
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Khoảng cách -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="#4CAF50" />

            <TextView
                android:id="@+id/tv_place_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.5 km từ vị trí của bạn"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Các nút hành động -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/btn_save_place"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lưu"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_share_place"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chia sẻ"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_nearby"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gần đây"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Nút chỉ đường lớn -->
        <Button
            android:id="@+id/btn_directions_bottom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚗 Chỉ đường đến trạm sạc"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/gradient_green_bg"
            android:textAllCaps="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:gravity="center"
            android:elevation="4dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>